<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- شريط علوي -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <ImageButton
                android:id="@+id/btnClosePayment"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_close"
                android:contentDescription="إغلاق"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="الدفع"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <View
                android:layout_width="36dp"
                android:layout_height="36dp"/>
        </LinearLayout>

        <!-- ==== بطاقة الدفع المرئية ==== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="190dp"
            android:orientation="vertical"
            android:background="@drawable/bg_credit_card"
            android:padding="20dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <View
                    android:layout_width="42dp"
                    android:layout_height="30dp"
                    android:background="@drawable/bg_card_chip"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_contactless"
                    android:contentDescription="بدون تلامس"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <TextView
                android:id="@+id/cardNumberPreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="•••• •••• •••• ••••"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="14dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="اسم صاحب البطاقة"
                        android:textColor="#CFEAFB"
                        android:textSize="10sp"/>

                    <TextView
                        android:id="@+id/cardNamePreview"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="---"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="صالحة حتى"
                        android:textColor="#CFEAFB"
                        android:textSize="10sp"/>

                    <TextView
                        android:id="@+id/cardExpiryPreview"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="••/••"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- ==== نموذج بيانات البطاقة ==== -->
        <EditText
            android:id="@+id/inputCardName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_input_field"
            android:hint="اسم صاحب البطاقة"
            android:inputType="textPersonName"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:layout_marginBottom="14dp"/>

        <EditText
            android:id="@+id/inputCardNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_input_field"
            android:hint="رقم البطاقة"
            android:inputType="number"
            android:maxLength="16"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:layout_marginBottom="14dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <EditText
                android:id="@+id/inputCardExpiry"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_input_field"
                android:hint="تاريخ الانتهاء MM/YY"
                android:inputType="number"
                android:maxLength="5"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"/>

            <EditText
                android:id="@+id/inputCardCvc"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_input_field"
                android:hint="رمز الأمان CVC"
                android:inputType="numberPassword"
                android:maxLength="3"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"/>

        </LinearLayout>

        <!-- ==== ملخص المبلغ ==== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:orientation="vertical"
                android:background="@drawable/bg_product_card"
                android:padding="14dp">

                <TextView
                    android:id="@+id/summaryTotal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0 LYD"
                    android:textColor="@color/text_primary"
                    android:textSize="17sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="المجموع"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:orientation="vertical"
                android:background="@drawable/bg_product_card"
                android:padding="14dp">

                <TextView
                    android:id="@+id/summaryDelivery"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0 LYD"
                    android:textColor="@color/text_primary"
                    android:textSize="17sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="التوصيل"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

        </LinearLayout>

        <Button
            android:id="@+id/btnPayNow"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="الدفع"
            android:textColor="@color/text_on_green"
            android:textStyle="bold"
            android:background="@drawable/bg_gradient_button"/>

    </LinearLayout>
</ScrollView>
